# Supabase (NEXT_PUBLIC_* are client-exposed — used by Auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key — powers LLM reading/oracle generation
ANTHROPIC_API_KEY=

# Absolute site URL for OAuth callbacks (deployed domain; defaults to http://localhost:3000)
NEXT_PUBLIC_SITE_URL=

# PII encryption / hashing
PII_ENC_KEY=          # 64 hex chars (32 bytes)
PII_HASH_KEY=

# Vercel Cron auth (Vercel injects automatically; manual calls use the matching x-*-secret headers)
CRON_SECRET=
# Retention sweep cron protection
RETENTION_SWEEP_SECRET=
# Pending-order reconciliation (/api/payments/reconcile) cron protection
PAYMENTS_RECONCILE_SECRET=
# Operator refund trigger (/api/payments/refund) protection. Unset -> that API is disabled (503)
PAYMENTS_ADMIN_SECRET=

# Dev-only: skip the payment gate and show the full reading (ignored in production)
DEV_UNLOCK_BYPASS=

# Stripe — set BOTH server secrets to switch from the stub to real payments (both-or-neither, else startup errors)
STRIPE_SECRET_KEY=              # server-only secret key (sk_...) — never expose to the client
STRIPE_WEBHOOK_SECRET=          # signing secret for /api/payments/stripe/webhook (whsec_...)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=  # client-exposed publishable key (pk_...) — no consumer in this hosted-Checkout design; uncomment only for a future client-side Stripe Elements integration
