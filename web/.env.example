# Supabase (NEXT_PUBLIC_* are client-exposed — used by Auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key — powers LLM reading/oracle generation
ANTHROPIC_API_KEY=

# Absolute site URL for OAuth callbacks (deployed domain; defaults to http://localhost:3000)
NEXT_PUBLIC_SITE_URL=

# PII encryption / hashing
PII_ENC_KEY=          # 64 hex chars (32 bytes)
PII_HASH_KEY=

# Vercel Cron auth (Vercel injects automatically; manual calls use the matching x-*-secret headers)
CRON_SECRET=
# Retention sweep cron protection
RETENTION_SWEEP_SECRET=
# Pending-order reconciliation (/api/payments/reconcile) cron protection
PAYMENTS_RECONCILE_SECRET=
# Operator refund trigger (/api/payments/refund) protection. Unset -> that API is disabled (503)
PAYMENTS_ADMIN_SECRET=

# Dev-only: skip the payment gate and show the full reading (ignored in production)
DEV_UNLOCK_BYPASS=

# Polar (PRIMARY payment provider) — set BOTH secrets to switch from the stub to real payments
# (both-or-neither, else startup errors). Polar is a Merchant of Record supporting Korea, with a
# review-free sandbox. Takes precedence over Stripe below when configured.
POLAR_ACCESS_TOKEN=             # server-only organization access token — never expose to the client
POLAR_WEBHOOK_SECRET=           # Standard Webhooks signing secret for /api/payments/polar/webhook (whsec_...)
POLAR_SERVER=                   # 'sandbox' (default) or 'production'
# Polar product-id UUIDs — created out of band via `pnpm exec tsx tools/polar-setup.ts` (run from web/),
# which prints these lines. One per credit package (reading 1/3/5, oracle 12/30/80).
POLAR_PRODUCT_ID_READING_1=
POLAR_PRODUCT_ID_READING_3=
POLAR_PRODUCT_ID_READING_5=
POLAR_PRODUCT_ID_ORACLE_12=
POLAR_PRODUCT_ID_ORACLE_30=
POLAR_PRODUCT_ID_ORACLE_80=

# Stripe (DORMANT — superseded by Polar; kept for a possible future US-entity revival). Only used if Polar
# is unconfigured. Set BOTH server secrets to activate (both-or-neither, else startup errors).
STRIPE_SECRET_KEY=              # server-only secret key (sk_...) — never expose to the client
STRIPE_WEBHOOK_SECRET=          # signing secret for /api/payments/stripe/webhook (whsec_...)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=  # client-exposed publishable key (pk_...) — no consumer in this hosted-Checkout design; uncomment only for a future client-side Stripe Elements integration
